              "selectionRange": {
                  "min": 0,
                  "max": 4
              },
              "keepCardOrder": false
          }
      },
      "beforeGameStart": {
        "initialBoardSetup": [
          {
            "drawFromTop": "Deck",
            "count": 8,
            "destination": "Life"
          }
        ]
